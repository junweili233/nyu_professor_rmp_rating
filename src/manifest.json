{
  "manifest_version": 3,
  "name": "NYU Albert RMP Ratings",
  "description": "Shows Rate My Professors ratings and useful comments beside professor names on NYU Albert.",
  "version": "0.1.6",
  "action": {
    "default_title": "NYU RMP",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://albert.nyu.edu/*",
        "https://sis.nyu.edu/*",
        "https://sis.portal.nyu.edu/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "host_permissions": [
    "https://www.ratemyprofessors.com/*"
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ]
}
